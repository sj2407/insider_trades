# Required: SEC requires you to identify yourself in the User-Agent header
SEC_USER_AGENT=Your Name your.email@example.com

# Polygon: primary price + ticker metadata source
POLYGON_API_KEY=

# Optional fallbacks (yfinance is used if these are missing)
FINNHUB_API_KEY=
FMP_API_KEY=

# Market-cap floor for "Russell-3000-ish" filtering (USD)
MIN_MARKET_CAP=100000000

# Daily lookback in hours for "new filings" (48 gives buffer for missed runs)
LOOKBACK_HOURS=48
